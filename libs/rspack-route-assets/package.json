{
  "name": "@jorvel/rspack-route-assets",
  "version": "0.2.0",
  "description": "Rspack/Webpack plugin that emits a per-route asset manifest for JORVEL preload tags.",
  "license": "MIT",
  "homepage": "https://github.com/Ravikisha/JorvelJS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ravikisha/JorvelJS.git",
    "directory": "libs/rspack-route-assets"
  },
  "keywords": [
    "jorvel",
    "rspack",
    "webpack",
    "plugin",
    "module-federation",
    "manifest"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "@rspack/core": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  }
}
