{
  "name": "@jorvel/adapter-cloudflare",
  "version": "0.2.0",
  "description": "Cloudflare Pages / Workers deployment adapter for JORVEL.",
  "license": "MIT",
  "homepage": "https://github.com/Ravikisha/JorvelJS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ravikisha/JorvelJS.git",
    "directory": "libs/adapter-cloudflare"
  },
  "keywords": [
    "jorvel",
    "cloudflare",
    "workers",
    "edge",
    "ssr",
    "module-federation"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@jorvel/ssr": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3"
  }
}
