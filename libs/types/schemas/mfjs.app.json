{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mfjs.dev/schemas/mfjs.app.json",
  "title": "MFJS App Config",
  "description": "Schema for mfjs.app.json — per-app metadata generated by `mfjs generate host|remote`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "type", "port"],
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "App name and Module Federation container."
    },
    "type": { "type": "string", "enum": ["host", "remote"] },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "exposes": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Exposed modules map (only meaningful on remotes)."
    },
    "shared": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
