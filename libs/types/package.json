{
  "name": "@moxjs/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types and runtime helpers for MOXJS configs, plugins, and federation contracts.",
  "license": "MIT",
  "homepage": "https://github.com/anthropics/MOXJS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/MOXJS.git",
    "directory": "libs/types"
  },
  "keywords": ["moxjs", "module-federation", "types", "config"],
  "private": false,
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./testing": { "types": "./dist/contract-test.d.ts", "import": "./dist/contract-test.js" },
    "./schemas/moxjs.config.json": "./schemas/moxjs.config.json",
    "./schemas/moxjs.app.json": "./schemas/moxjs.app.json",
    "./schemas/moxjs.federation.json": "./schemas/moxjs.federation.json",
    "./package.json": "./package.json"
  },
  "files": ["dist", "schemas", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
