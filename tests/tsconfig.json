{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": [
      "../packages/cli/node_modules/@types",
      "../node_modules/@types"
    ],
    "paths": {
      "@jorvel/types": ["../libs/types/src/index.ts"],
      "@jorvel/runtime": ["../libs/runtime/src/index.ts"],
      "@jorvel/event-bus": ["../libs/event-bus/src/index.ts"],
      "@jorvel/ssr": ["../libs/ssr/src/index.ts"]
    }
  },
  "include": ["e2e/**/*.ts"],
  "exclude": ["node_modules"]
}
